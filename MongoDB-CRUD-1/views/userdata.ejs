<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>User Grid</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        /* Body & container */
        body {
            background: #f4f6fb;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        .container h3 {
            font-weight: 600;
            color: #111827;
        }

        /* User Card */
        .user-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
            transition: transform 0.3s, box-shadow 0.3s;
            background: #fff;
        }

        .user-card:hover {
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
        }

        .avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #4f46e5, #9333ea);
            color: #fff;
            font-weight: 600;
            font-size: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px auto;
        }

        h6 {
            font-weight: 600;
            color: #111827;
        }

        /* User info */
        .info-label {
            font-size: 12px;
            color: #6b7280;
        }

        .info-value {
            font-size: 14px;
            font-weight: 500;
            color: #111827;
        }

        .card-body {
            padding: 20px;
        }

        /* Buttons */
        .btn-sm {
            border-radius: 6px;
        }

        .btn-sm a {
            display: block;
        }

        /* No user message styling */
        h4 {
            text-align: center;
            width: 100%;
            padding: 40px 0;
            color: #6b7280;
            font-size: 20px;
            font-weight: 500;
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
            margin-top: 20px;
        }
    </style>
</head>

<body>

    <div class="container py-5">
        <h3 class="mb-4 text-center">User Directory</h3>
        <div class="row g-4">

            <%data.map((val,index)=>{ %>

                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card user-card">
                        <div class="card-body text-center">
                            <div class="avatar"><%-val.userName.charAt(0)%></div>
                            <h6 class="mb-2"><%-val.userName%></h6>

                            <div class="text-start mt-3">
                                <div>
                                    <span class="info-label">Name</span><br>
                                    <span class="info-value"><%-val.userName%></span>
                                </div>

                                <div class="mt-2">
                                    <span class="info-label">Email</span><br>
                                    <span class="info-value"><%-val.userEmail%></span>
                                </div>

                                <div class="mt-2">
                                    <span class="info-label">Phone</span><br>
                                    <span class="info-value">+91 <%-val.userPhone%></span>
                                </div>
                            </div>

                            <div class="d-flex gap-2 mt-3">
                                <button class="btn btn-primary btn-sm w-100"><a href="/delete/<%-val._id%>"
                                        onclick="return confirm('Do you want to delete this user?')"
                                        class="text-white text-decoration-none">Delete</a></button>
                                <button class="btn btn-secondary btn-sm w-100">
                                    <a class="text-white text-decoration-none"
                                        href="/edit/<%-val._id%>">Edit</a></button>
                            </div>
                        </div>
                    </div>
                </div>

                <% })%>

                    <!-- IF NO USER EXISTS -->
                    <%if(data.length==0) { %>
                        <h4>User Not Exists</h4>
                        <%}%>
        </div>
    </div>

</body>

</html>