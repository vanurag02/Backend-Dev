<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>User Grid</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f5f7fb;
        }

        .user-card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
            transition: 0.3s;
        }

        .user-card:hover {
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.12);
        }

        .avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #4f46e5, #9333ea);
            color: #fff;
            font-weight: bold;
            font-size: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 10px;
        }

        .info-label {
            font-size: 12px;
            color: #888;
        }

        .info-value {
            font-size: 14px;
            font-weight: 500;
            color: #333;
        }

        .card-body {
            padding: 20px;
        }

        .btn-sm {
            border-radius: 6px;
        }
    </style>
</head>

<body>

    <div class="container py-5">
        <h3 class="mb-4 text-center">User Directory</h3>
        <div class="row g-4">

            <%data.map((val,index)=>{ %>

                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card user-card">
                        <div class="card-body text-center">
                            <div class="avatar"><%-val.userName.charAt(0)%></div>
                            <h6 class="mb-2"><%-val.userName%></h6>

                            <div class="text-start mt-3">
                                <div>
                                    <span class="info-label">Name</span><br>
                                    <span class="info-value"><%-val.userName%></span>
                                </div>

                                <div class="mt-2">
                                    <span class="info-label">Email</span><br>
                                    <span class="info-value"><%-val.userEmail%></span>
                                </div>

                                <div class="mt-2">
                                    <span class="info-label">Phone</span><br>
                                    <span class="info-value">+91 <%-val.userPhone%></span>
                                </div>
                            </div>

                            <div class="d-flex gap-2 mt-3">
                                <button class="btn btn-primary btn-sm w-100"><a href="/delete/<%-val._id%>"
                                        onclick="return confirm('Do you want to delete this user?')"
                                        class="text-white">Delete</a></button>
                                <button class="btn btn-outline-secondary btn-sm w-100"><a
                                        href="/edit/<%-val._id%>">Edit</a></button>
                            </div>
                        </div>
                    </div>
                </div>

                <% })%>

                    <!-- IF NO USER EXISTS -->
                    <%if(data.length==0) { %>
                        <h4>User Not Exists</h4>
                        <%}%>
        </div>
    </div>

</body>

</html>