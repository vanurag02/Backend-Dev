<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>User Profiles</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- BOOTSTRAP CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* PAGE HEADER */
        .page-header {
            background: linear-gradient(135deg, #0d6efd, #0a58ca);
            color: white;
            padding: 40px 20px;
            text-align: center;
            margin-bottom: 40px;
        }

        /* PROFILE CARD */
        .profile-card {
            border: none;
            border-radius: 15px;
            overflow: hidden;
            transition: 0.3s;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
            background: #fff;
        }

        .profile-card:hover {
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        }

        /* PROFILE IMAGE */
        .profile-img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 50%;
            margin: 20px auto 10px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        /* CARD BODY */
        .card-body {
            text-align: center;
        }

        .card-title {
            font-weight: bold;
            margin-bottom: 5px;
        }

        .user-email {
            color: #6c757d;
            font-size: 14px;
        }

        .info {
            text-align: left;
            margin-top: 15px;
        }

        .info p {
            margin-bottom: 8px;
            font-size: 14px;
        }

        /* BUTTON */
        .btn-view {
            width: 100%;
            border-radius: 8px;
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="page-header">
        <h1>Our Community Profiles</h1>
        <p>Connect with professionals and explore user profiles</p>
    </div>

    <!-- PROFILE LIST -->
    <div class="container mb-5">
        <div class="row g-4">
            <!-- USER CARD -->
            <% data.map((val, index)=>{%>

                <div class="col-md-4">
                    <div class="card profile-card">

                        <img src="uploads/<%-val.userProfile%>" class="profile-img" alt="User">

                        <div class="card-body">

                            <h5 class="card-title">
                                <%- val.userName %>
                            </h5>
                            <p class="user-email">
                                <%-val.userEmail%>
                            </p>

                            <div class="info">
                                <p><strong>Phone:</strong>
                                    <%-val.userPhone%>
                                </p>
                                <p><strong>Address:</strong>
                                    <%-val.userAddress%>
                                </p>
                            </div>


                            <a href="/edit/<%-val._id%>" style="color: white; text-decoration: none;">
                                <button class="btn btn-primary btn-view mt-3">
                                    Edit
                                </button>
                            </a>
                            <a href="/delete/<%-val._id%>" style="color: white; text-decoration: none;">
                                <button class="btn btn-primary btn-view mt-3"
                                    onclick="return confirm('Do you want to delete this profile?')">
                                    Delete
                                </button>
                            </a>

                        </div>
                    </div>
                </div>
                <%}) %>
        </div>
    </div>
</body>

</html>